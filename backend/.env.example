# ═══════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ═══════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (Choose one method)
# ═══════════════════════════════════════════════════════════

# Method 1: Supabase PostgreSQL URL (RECOMMENDED for Render deployment)
# Get from: https://app.supabase.com/project/[project]/settings/database
DATABASE_URL=postgresql://postgres:[password]@[host]:[port]/[database]?sslmode=require

# Method 2: Individual Parameters (for local/Docker development)
# Uncomment and fill these if not using DATABASE_URL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hms_db
# DB_USER=postgres
# DB_PASSWORD=postgres123

# ─── JWT ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ─── Frontend URL (CORS) ──────────────────────────────────
# Update this to your Vercel frontend URL for deployment
CLIENT_URL=https://your-frontend-vercel-url.vercel.app

# ─── Email (nodemailer) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourhospital.com
SMTP_PASS=your_email_password

# ─── Cloud Storage (AWS S3) ───────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=hms-files
